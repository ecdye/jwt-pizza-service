{
  "collectCoverage": true,
  "coverageReporters": ["json-summary", "text"],
  "coverageThreshold": {
    "global": {
      "lines": 80
    }
  },
  "testEnvironment": "node",
  "globalSetup": "<rootDir>/jest.globalSetup.js",
  "globalTeardown": "<rootDir>/jest.globalTeardown.js",
  "testTimeout": 30000,
  "maxWorkers": 1
}
